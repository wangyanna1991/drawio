        <mxCell id="edge2" edge="1" parent="1" source="q2_box" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=3;strokeColor=#94a3b8;endArrow=block;" target="vision">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge3" edge="1" parent="1" source="q3_box" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=3;strokeColor=#94a3b8;endArrow=block;" target="vision">
          <mxGeometry relative="1" as="geometry">
